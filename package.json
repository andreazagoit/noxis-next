    "@react-three/postprocessing": "^3.0.4",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.39.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "16.1.7",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "postprocessing": "^6.39.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.4",
